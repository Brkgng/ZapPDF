<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Document Types: Declare ZapPDF as a PDF handler -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>PDF Document</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.adobe.pdf</string>
            </array>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
        </dict>
    </array>

    <!-- Internal drag-and-drop type for in-app file row reordering -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
            </array>
            <key>UTTypeDescription</key>
            <string>ZapPDF Internal Reorder File Identifier</string>
            <key>UTTypeIdentifier</key>
            <string>com.zappdf.internal.reorder-file-id</string>
        </dict>
    </array>
    
    <!-- macOS: Support opening documents in place (required for sandboxed apps) -->
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    
    <!-- iOS: Camera access for document scanning -->
    <key>NSCameraUsageDescription</key>
    <string>ZapPDF uses the camera to scan physical documents and convert them to PDF.</string>

    <!-- RevenueCat: public SDK key injected from xcconfig at build time -->
    <key>REVENUECAT_API_KEY</key>
    <string>$(REVENUECAT_API_KEY)</string>
</dict>
</plist>
