    "'%@' appears to be corrupted.": {
      "comment": "Error when PDF is corrupted",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' scheint beschädigt zu sein."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » semble être corrompu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' parece estar dañado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」は破損しているようです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」似乎已损坏。"
          }
        },
        "tr": {
