          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' está protegido con contraseña."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » est protégé par mot de passe."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」はパスワードで保護されています。"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' parola korumalı."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
