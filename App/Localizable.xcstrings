    "'%@' appears to be corrupted." : {
      "comment" : "Error when PDF is corrupted",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' scheint beschädigt zu sein."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' parece estar dañado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » semble être corrompu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」は破損しているようです。"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' bozuk görünüyor."
          }
