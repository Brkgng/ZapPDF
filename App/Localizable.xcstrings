          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' no es un archivo PDF válido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » n'est pas un fichier PDF valide."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」は有効なPDFファイルではありません。"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%@' geçerli bir PDF dosyası değil."
