    "Could not load '%@'. Please select a valid PDF file.": {
      "comment": "Single file load error",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' konnte nicht geladen werden. Bitte wähle eine gültige PDF-Datei."
