    },
    "'%@' is not a valid PDF file.": {
      "comment": "Error when file is not a valid PDF",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' ist keine gültige PDF-Datei."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » n'est pas un fichier PDF valide."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' no es un archivo PDF válido."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」は有効なPDFファイルではありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」不是有效的PDF文件。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' geçerli bir PDF dosyası değil."
          }
