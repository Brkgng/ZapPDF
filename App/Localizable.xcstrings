    "onboarding.privacyDescription": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Ihre PDFs werden lokal auf Ihrem Gerät verarbeitet. Nichts wird in die Cloud hochgeladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "All your PDFs are processed locally on your device. Nothing is ever uploaded to the cloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous vos PDF sont traités localement sur votre appareil. Rien n'est jamais envoyé vers le cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos tus PDFs se procesan localmente en tu dispositivo. Nada se sube nunca a la nube."
